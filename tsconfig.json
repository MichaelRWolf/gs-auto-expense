{
  "compilerOptions": {
    //
    // Google Apps Script uses ES5 JavaScript,
    "target": "ES5",
    //
    // CommonJS modules for Node.js style imports,
    "module": "commonjs",
    //
    // Output directory for compiled files,
    "outDir": "./dist",
    //
    // Source directory for TypeScript files,
    "rootDir": "./src",
    //
    // Enable all strict type-checking options,
    "strict": true,
    //
    // Allows default imports from modules with no default export,
    "esModuleInterop": true
  },
  "include": [
    // Include all TypeScript files in the 'src' directory,
    "src/**/*.ts"
  ]
}
